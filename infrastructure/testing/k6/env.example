# K6 yük testi — örnek ortam (değerleri kendi staging değerlerinizle doldurun).
# Bu dosyayı .env olarak kopyalamayın; sırları repoya koymayın.

# Fastify (API gateway) kök URL
R3MES_API_BASE=https://api.staging.example

# FastAPI (inference) kök URL — K8s içinde ayrı Service olabilir
R3MES_AI_BASE=https://ai.staging.example

# İsteğe bağlı Bearer (staging token)
# R3MES_AUTH_TOKEN=

# İsteğe bağlı sohbet parametreleri
# R3MES_CHAT_MODEL=qwen2.5-3b-instruct
# R3MES_CHAT_MAX_TOKENS=32
