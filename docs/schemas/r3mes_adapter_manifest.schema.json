{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://r3mes.dev/schemas/r3mes_adapter_manifest.schema.json",
  "title": "R3MES LoRA GGUF adaptör paketi manifesti (ZIP içi zorunlu dosya)",
  "description": "Eğiticilerin yükleyeceği .zip paketinin kökünde bulunması gereken r3mes_adapter_manifest.json. Yalnızca LoRA + GGUF ağırlıkları (llama.cpp uyumlu).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_format",
    "base_model",
    "adapter",
    "integrity",
    "submitted_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.\\d+$"
    },
    "package_format": {
      "type": "string",
      "const": "r3mes-lora-gguf-zip"
    },
    "base_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "variant", "frozen_core_sha256"],
      "properties": {
        "family": { "type": "string", "const": "bitnet" },
        "variant": { "type": "string", "const": "b1.58" },
        "frozen_core_cid": {
          "type": "string",
          "pattern": "^(Qm[1-9A-HJ-NP-Za-km-z]{44}|bafy[a-z2-7]{50,})$"
        },
        "frozen_core_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "weight_files"],
      "properties": {
        "kind": { "type": "string", "const": "LORA" },
        "weight_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/weight_file_entry" }
        },
        "notes": { "type": "string", "maxLength": 1024 }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weight_sha256_alg"],
      "properties": {
        "weight_sha256_alg": { "type": "string", "const": "sha256" },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "trainer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wallet_address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "display_name": { "type": "string", "maxLength": 128 }
      }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9\\-]{2,32}$" },
      "maxItems": 16
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "submitted_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string", "maxLength": 2048 }
  },
  "$defs": {
    "weight_file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "role"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/\\-]+\\.gguf$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "role": {
          "type": "string",
          "enum": ["primary", "shard"]
        },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
