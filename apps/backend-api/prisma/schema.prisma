generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdapterKind {
  LORA
  DORA
}

enum AdapterStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  SLASHED
  DEPRECATED
}

enum AdapterArtifactFormat {
  GGUF
  PEFT
}

enum AdapterRuntime {
  LLAMA_CPP
  TRANSFORMERS
}

enum AiQueryStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum KnowledgeVisibility {
  PRIVATE
  PUBLIC
}

enum KnowledgeSourceType {
  TEXT
  MARKDOWN
  JSON
  PDF
  DOCX
  PPTX
  HTML
}

enum KnowledgeParseStatus {
  PENDING
  READY
  FAILED
}

enum KnowledgeIngestionStepStatus {
  PENDING
  RUNNING
  READY
  FAILED
  PARTIAL_READY
  SKIPPED
}

enum KnowledgeIngestionJobStage {
  RECEIVED
  STORAGE
  PARSE
  CHUNK
  EMBEDDING
  VECTOR_INDEX
  QUALITY
  READY
}

enum KnowledgeIngestionJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL_READY
}

enum KnowledgeFeedbackKind {
  GOOD_SOURCE
  WRONG_SOURCE
  MISSING_SOURCE
  BAD_ANSWER
  GOOD_ANSWER
}

enum KnowledgeFeedbackProposalAction {
  BOOST_SOURCE
  PENALIZE_SOURCE
  REVIEW_MISSING_SOURCE
  REVIEW_ANSWER_QUALITY
}

enum KnowledgeFeedbackProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KnowledgeFeedbackApplyStatus {
  PLANNED
  GATE_PASSED
  APPLIED
  ROLLED_BACK
  BLOCKED
}

enum KnowledgeFeedbackRouterAdjustmentStatus {
  ACTIVE
  ROLLED_BACK
}

model User {
  id             String   @id @default(cuid())
  walletAddress  String   @unique
  displayName    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adapters             Adapter[]             @relation("OwnerAdapters")
  aiQueries            AiQuery[]
  knowledgeCollections KnowledgeCollection[]
  knowledgeFeedback    KnowledgeFeedback[]
  knowledgeFeedbackProposals KnowledgeFeedbackProposal[]
  knowledgeFeedbackApplyRecords KnowledgeFeedbackApplyRecord[]
  knowledgeFeedbackRouterAdjustments KnowledgeFeedbackRouterAdjustment[]
}

/// LoRA / DoRA adaptörü — zincir + off-chain metadata
model Adapter {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("OwnerAdapters", fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  kind        AdapterKind @default(LORA)
  format      AdapterArtifactFormat @default(GGUF)
  runtime     AdapterRuntime        @default(LLAMA_CPP)
  baseModel   String?
  storagePath String?

  weightsCid  String?
  manifestCid String?

  /// Sui `adapter_registry::Adapter` nesne ID
  onChainObjectId String? @unique

  /// Sui u64 — zincir üzerindeki sıra numarası
  onChainAdapterId BigInt? @unique

  status         AdapterStatus @default(PENDING_REVIEW)
  benchmarkScore Decimal?      @db.Decimal(10, 6)
  domainTags     String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiQueries AiQuery[]

  @@index([status, benchmarkScore])
  @@index([ownerId])
}

model KnowledgeCollection {
  id          String              @id @default(cuid())
  ownerId     String
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  visibility  KnowledgeVisibility @default(PRIVATE)
  autoMetadata Json?
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  documents KnowledgeDocument[]
  feedback  KnowledgeFeedback[]
  feedbackProposals KnowledgeFeedbackProposal[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([visibility, publishedAt])
}

model KnowledgeFeedback {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   KnowledgeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  documentId           String?
  chunkId              String?
  expectedCollectionId String?
  traceId              String?
  queryHash            String?

  kind   KnowledgeFeedbackKind
  reason String?               @db.Text
  metadata Json?

  appliedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([collectionId, kind, createdAt(sort: Desc)])
  @@index([queryHash])
  @@index([traceId])
}

model KnowledgeFeedbackProposal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   KnowledgeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  expectedCollectionId String?
  action               KnowledgeFeedbackProposalAction
  status               KnowledgeFeedbackProposalStatus @default(PENDING)
  queryHash            String?
  confidence           Float                           @default(0)
  evidence             Json
  reason               String                          @db.Text

  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  applyRecords KnowledgeFeedbackApplyRecord[]
  routerAdjustments KnowledgeFeedbackRouterAdjustment[]

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([collectionId, action, status])
  @@index([queryHash])
}

model KnowledgeFeedbackApplyRecord {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  proposalId String
  proposal   KnowledgeFeedbackProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  status       KnowledgeFeedbackApplyStatus @default(PLANNED)
  plan         Json
  gateReport   Json?
  appliedDelta Json?
  rollbackPlan Json?
  reason       String?                      @db.Text

  plannedAt    DateTime @default(now())
  gateCheckedAt DateTime?
  appliedAt    DateTime?
  rolledBackAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  routerAdjustments KnowledgeFeedbackRouterAdjustment[]

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([proposalId, status])
}

model KnowledgeFeedbackRouterAdjustment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  proposalId String
  proposal   KnowledgeFeedbackProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  applyRecordId String
  applyRecord   KnowledgeFeedbackApplyRecord @relation(fields: [applyRecordId], references: [id], onDelete: Cascade)

  status KnowledgeFeedbackRouterAdjustmentStatus @default(ACTIVE)

  stepId               String
  kind                 String
  mutationPath         String
  collectionId         String?
  expectedCollectionId String?
  queryHash            String?
  scoreDelta           Float
  simulatedBefore      Float?
  simulatedAfter       Float?
  metadata             Json?
  rollbackReason       String? @db.Text

  createdAt    DateTime @default(now())
  rolledBackAt DateTime?
  updatedAt    DateTime @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([applyRecordId, status])
  @@index([proposalId, status])
  @@index([collectionId, queryHash, status])
}

model KnowledgeDocument {
  id           String               @id @default(cuid())
  collectionId String
  collection   KnowledgeCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  title        String
  sourceType   KnowledgeSourceType
  sourceMime      String?
  sourceExtension String?
  contentHash     String?
  parserId        String?
  parserVersion   Int?
  storageCid   String?
  storagePath  String?
  scanStatus    KnowledgeIngestionStepStatus @default(PENDING)
  storageStatus KnowledgeIngestionStepStatus @default(PENDING)
  autoMetadata Json?
  parseStatus  KnowledgeParseStatus @default(PENDING)
  chunkStatus       KnowledgeIngestionStepStatus @default(PENDING)
  embeddingStatus   KnowledgeIngestionStepStatus @default(PENDING)
  vectorIndexStatus KnowledgeIngestionStepStatus @default(PENDING)
  qualityStatus     KnowledgeIngestionStepStatus @default(PENDING)
  readinessStatus   KnowledgeIngestionStepStatus @default(PENDING)
  errorMessage String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  chunks KnowledgeChunk[]
  ingestionJob IngestionJob?
  versions KnowledgeDocumentVersion[]
  artifacts KnowledgeArtifact[]

  @@index([collectionId, createdAt(sort: Desc)])
  @@index([contentHash])
  @@index([parseStatus, createdAt])
  @@index([scanStatus, storageStatus])
  @@index([readinessStatus, createdAt])
  @@index([vectorIndexStatus, createdAt])
}

model KnowledgeDocumentVersion {
  id              String              @id @default(cuid())
  documentId      String
  document        KnowledgeDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version         Int
  versionIndex    Int                 @default(1)
  sourceType      KnowledgeSourceType
  sourceMime      String?
  sourceExtension String?
  parserId        String
  parserVersion   Int
  contentHash     String?
  storagePath     String?
  storageCid      String?
  readinessStatus KnowledgeIngestionStepStatus @default(PENDING)
  textHash        String
  originalBytes   Int?
  normalizedChars Int
  warnings        String[]            @default([])
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  artifacts KnowledgeArtifact[]
  chunks    KnowledgeChunk[]

  @@unique([documentId, version])
  @@unique([documentId, versionIndex])
  @@unique([documentId, contentHash])
  @@index([documentId, createdAt(sort: Desc)])
  @@index([contentHash])
  @@index([parserId, parserVersion])
  @@index([readinessStatus, createdAt])
  @@index([textHash])
}

model KnowledgeArtifact {
  id                 String                    @id @default(cuid())
  documentId         String
  document           KnowledgeDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId          String?
  version            KnowledgeDocumentVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  artifactId         String
  artifactKey        String?
  ordinal            Int
  kind               String
  page               Int?
  pageNumber         Int?
  title              String?
  level              Int?
  text               String                    @db.Text
  metadata           Json?
  answerabilityScore Int?
  createdAt          DateTime                  @default(now())

  chunks KnowledgeChunk[]

  @@unique([artifactKey])
  @@unique([documentId, versionId, artifactId])
  @@index([documentId, artifactId])
  @@index([versionId, kind])
  @@index([kind])
  @@index([page])
}

model IngestionJob {
  jobId      String                      @id @default(cuid())
  documentId String                      @unique
  document   KnowledgeDocument           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  stage      KnowledgeIngestionJobStage  @default(RECEIVED)
  status     KnowledgeIngestionJobStatus @default(QUEUED)
  attempts   Int                         @default(0)
  errorCode  String?
  errorMessage String?                   @db.Text
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@index([documentId])
  @@index([status, createdAt])
  @@index([stage, status])
}

model KnowledgeChunk {
  id         String            @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String            @db.Text
  tokenCount Int
  autoMetadata Json?
  versionId  String?
  version    KnowledgeDocumentVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  artifactRowId String?
  artifact   KnowledgeArtifact? @relation(fields: [artifactRowId], references: [id], onDelete: SetNull)
  artifactId String?
  artifactSplitIndex Int?
  createdAt  DateTime          @default(now())

  embedding KnowledgeEmbedding?

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([versionId])
  @@index([artifactRowId])
  @@index([artifactId])
}

model KnowledgeEmbedding {
  id       String         @id @default(cuid())
  chunkId  String         @unique
  chunk    KnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  values   Float[]
  vector   Unsupported("vector(256)")?
  createdAt DateTime      @default(now())

  @@index([chunkId])
}

model AiQuery {
  id             String  @id @default(cuid())
  idempotencyKey String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  adapterId String?
  adapter   Adapter? @relation(fields: [adapterId], references: [id], onDelete: Restrict)

  status AiQueryStatus @default(QUEUED)

  queueJobId String?

  promptHash    String?
  promptPreview String?

  knowledgeCollectionIds String[] @default([])
  sourceSummary          Json?

  billedAmountNano BigInt? @default(0)

  resultSummary String? @db.Text
  errorCode     String?
  errorMessage  String? @db.Text

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([adapterId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

/// Sui `queryEvents` imleri — `adapter_registry` ve `staking_pool` ayrı akış
model IndexerCheckpoint {
  id                  String   @id @default("singleton")
  cursorAdapterModule String?
  cursorStakingModule String?
  updatedAt           DateTime @updatedAt
}

/// Wallet imza mesajındaki `jti` tek kullanımlık kayıt (replay önleme)
model WalletAuthJti {
  jti       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// QA webhook idempotency — aynı `jobId` ile tekrar teslimatta çift on-chain/DB güncellemesi önlenir
model QaWebhookReceipt {
  jobId      String   @id
  bodySha256 String
  /// İşlem başarıyla bittiğinde set edilir; null iken aynı jobId tekrar gelirse in-flight kabul edilir
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

/// Eğitici stake read model — `StakingPool` olaylarından türetilir
model StakePosition {
  id String @id @default(cuid())

  trainerAddress   String
  onChainAdapterId BigInt @unique

  amountNano BigInt

  poolObjectId String?

  updatedAt DateTime @updatedAt

  @@index([trainerAddress])
}
