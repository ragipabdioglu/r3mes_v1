# R3MES local backend örneği — Qwen2.5-3B + RAG-first MVP
# Legacy BitNet/QVAC notları legacy / R&D belgelerinde tutulur.

# PostgreSQL (Prisma)

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/r3mes"



# Redis (BullMQ + /ready health)

REDIS_URL="redis://127.0.0.1:6379"



# Sui RPC — Testnet

SUI_RPC_URL="https://fullnode.testnet.sui.io:443"



# Testnet deploy (tx AgXkhHzvXPN4TYWNYEZnwHgQ4dKN9LTAsDS36rg4h9Yn)

R3MES_COIN_TYPE="0xd5a6f9e7dd18997ed39e1e584b1ec60d636bf295fbe43ccb09cd8a906d2c0204::r3mes_coin::R3MES_COIN"

R3MES_PACKAGE_ID="0xd5a6f9e7dd18997ed39e1e584b1ec60d636bf295fbe43ccb09cd8a906d2c0204"

R3MES_REWARD_POOL_OBJECT_ID="0xfedcd2a9978c0ef7d9289c147d19d1321bf9dd63540e01318dbe6be1723f6c29"

R3MES_STAKING_POOL_OBJECT_ID="0x71dd2872872d1598a0785a5ff4ccd97fb75929103de04c222b7e2cb4e1a39cf0"

R3MES_SUPPLY_STATE_OBJECT_ID="0xca010b91b53af24bdf1a99d8e47e0499724573b85d806003d73e2ebaa404658e"

