# Owned `reward_pool::OperatorCap` — `record_usage` için zorunlu (Move imzası: OperatorCap, pool, fee, user).
# Publish sonrası objectChanges veya deployer adresindeki owned nesnelerden; @r3mes/shared-types içindeki
# R3MES_TESTNET_MOCK_OPERATOR_CAP_OBJECT_ID boşsa bu env zorunludur.
# R3MES_OPERATOR_CAP_OBJECT_ID="0x..."



# HTTP (dApp varsayılanı 3001; API 3000 — NEXT_PUBLIC_BACKEND_URL ile eşleşmeli)

PORT=3000

HOST=0.0.0.0

# CORS: üretim/staging dApp kökeni (örn. https://app.example.com). Tanımlı değilse yalnızca localhost.
# Virgülle birden fazla origin.
# R3MES_ALLOWED_ORIGIN="https://app.example.com"


# --- Web3 cüzdan imzası (Faz 8.3) — POST /v1/chat/completions, POST /v1/adapters ---

# X-Message JSON örneği: {"exp":<unix_saniye>,"iat":<opsiyonel>,"address":"0x..."}

# R3MES_AUTH_CLOCK_SKEW_SEC=120

# R3MES_AUTH_MAX_TTL_SEC=900

# R3MES_AUTH_MAX_IAT_AGE_SEC=300

# İmzalı mesajda jti zorunlu (üretim önerisi); jti gönderilirse tek kullanımlık DB kaydı (replay önleme)
# R3MES_REQUIRE_WALLET_JTI=1

# Global rate limit (@fastify/rate-limit): R3MES_DISABLE_RATE_LIMIT=1 yalnızca dev/test
# R3MES_RATE_LIMIT_MAX=100
# R3MES_RATE_LIMIT_WINDOW=1 minute

# Yalnızca yerel geliştirme: imza doğrulamasını atla (R3MES_DEV_WALLET zorunlu)
# NODE_ENV=production iken R3MES_SKIP_WALLET_AUTH / R3MES_SKIP_CHAT_FEE açılamaz (uygulama başlamaz).

# Yalnızca NODE_ENV=development veya test: upload sonrası kuyruk/QA atla, ACTIVE + domainTags dev_bypass_qa (benchmarkScore null). Üretimde yasak.
# R3MES_DEV_BYPASS_QA=1

# R3MES_SKIP_WALLET_AUTH=1

# R3MES_DEV_WALLET="0x..."

# Kubo API (docker-compose.storage — 5001)

# IPFS_API_URL="http://127.0.0.1:5001"

# IPFS HTTP gateway — Nginx ön yüzü; host portu 9080 (llama-server 8080 ile çakışmaması için)

# R3MES_IPFS_GATEWAY_URL="http://127.0.0.1:9080"



# --- Operatör (on-chain tx) — gerçek testnet kullanımında doldurun ---

# sui keystore export veya sui keytool — Bech32 gizli anahtar

# R3MES_OPERATOR_PRIVATE_KEY="suiprivkey..."

# Chat ücreti (1 MIST): operatör anahtarı + paket + reward pool + OperatorCap nesne ID gerekir; eksikse 503.
# --- R3MES_SKIP_CHAT_FEE (yalnızca development / staging) ---
# Yerel veya staging: ücret TX'i atlamak için açılabilir. Üretimde (NODE_ENV=production) ayarlanırsa uygulama
# başlarken hata verir (app.ts — güvensiz bayrak yasak). Yani production'da chat ücreti ya düzgün yapılandırılır
# ya da servis ayakta kalmaz; "üretimde skip" desteklenmez.
# R3MES_SKIP_CHAT_FEE=1

# AI Engine (chat proxy hedefi — Qwen2.5-3B varsayılan inference)

# R3MES_AI_ENGINE_URL="http://127.0.0.1:8000"
# Yeni ana runtime: transformers_peft
# Legacy runtime: llama_cpp
# R3MES_AI_RUNTIME="transformers_peft"

# RAG embedding / retrieval
# Quality profile: Qdrant uses BGE-M3-compatible 1024d embeddings from ai-engine.
# Deterministic embeddings are only a local fallback/smoke escape hatch, not the quality path.
# R3MES_KNOWLEDGE_EMBED_DIM=256
# Retrieval engine:
# - prisma: legacy Prisma/lexical retrieval
# - qdrant: Qdrant vector retrieval
# - hybrid: resmi yol; Qdrant + Prisma aday havuzunu birleştirir, dedupe eder, pre-rank + rerank ile top kaynakları seçer
# R3MES_RETRIEVAL_ENGINE="hybrid"
# R3MES_ENABLE_TRUE_HYBRID_RETRIEVAL=1
# R3MES_QDRANT_URL="http://127.0.0.1:6333"
# R3MES_QDRANT_COLLECTION="r3mes_knowledge"
# R3MES_QDRANT_VECTOR_SIZE=1024
# R3MES_EMBEDDING_PROVIDER="ai-engine"
# R3MES_EMBEDDING_MODEL="BAAI/bge-m3"
# R3MES_REQUIRE_REAL_EMBEDDINGS=1
# R3MES_QDRANT_REINDEX_REQUIRE_REAL_EMBEDDINGS=1
# R3MES_HYBRID_QDRANT_LIMIT=15
# R3MES_HYBRID_PRISMA_LIMIT=15
# R3MES_HYBRID_PRERANK_LIMIT=8
# R3MES_RAG_FINAL_SOURCE_LIMIT=3
# R3MES_RAG_MIN_RERANK_SCORE=0.9
# R3MES_RAG_RELATIVE_SCORE_FLOOR=0.45
# R3MES_RAG_CONTEXT_MODE="compact"
# R3MES_CHAT_RESPONSE_MODE="natural"
# High/medium grounded non-medical RAG cevaplarında Qwen çağrısını atlayıp deterministic composer döndürür.
# UI latency'yi ciddi düşürür; medical için varsayılan kapalıdır. Medical'i de zorlamak için: force-medical.
# R3MES_ENABLE_RAG_FAST_PATH=1

# Optional latency escape hatch: compose high/medium-confidence RAG answers
# deterministically from extracted evidence. Keep this off for product-quality UI
# responses; enable only for smoke/eval speed checks.
# R3MES_ENABLE_FAST_GROUNDED_COMPOSER=0

# Knowledge ingestion parser POC
# Default upload support is .txt/.md/.json.
# Set an external parser command to opt into .pdf/.docx ingestion. The command
# receives a temporary local file path via {input} and must print clean
# Markdown/text to stdout. Keep unset in production until the parser is vetted.
# Examples:
# R3MES_DOCUMENT_PARSER_COMMAND="docling"
# R3MES_DOCUMENT_PARSER_ARGS="{input} --to md"
# R3MES_DOCUMENT_PARSER_TIMEOUT_MS=30000

# Knowledge reranker
# deterministic: yalnız mevcut TS reranker
# model: ai-engine içindeki HF reranker endpoint'i; quality profile için önerilen yol
# R3MES_RERANKER_MODE="model"
# R3MES_REQUIRE_REAL_RERANKER=1
# R3MES_RERANKER_TIMEOUT_MS=8000
# R3MES_RERANKER_CANDIDATE_LIMIT=8
# R3MES_RERANKER_MODEL_WEIGHT=1.75

# POST /v1/internal/qa-result — X-QA-HMAC (HAM gövde üzerinde HMAC-SHA256 hex)

# R3MES_QA_WEBHOOK_SECRET="..."
