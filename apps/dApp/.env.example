# Fastify backend — Studio/marketplace/chat istekleri buraya gider.
# Bu adres 3000'de dinleyen @r3mes/backend-api ile AYNI olmalı (pnpm --filter @r3mes/backend-api dev).
# API çalışmıyorsa tarayıcıda net::ERR_CONNECTION_REFUSED görürsünüz; önce GET /health doğrulayın.
# dApp ayrı portta: next dev -p 3001 (çakışma yok).

NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3000

# Backend R3MES_REQUIRE_WALLET_JTI=1 ile birlikte: imzada jti (replay önleme), önbellek kapalı
# NEXT_PUBLIC_R3MES_REQUIRE_WALLET_JTI=1

# Chat: POST /v1/chat/completions (backend proxy). İsteğe bağlı model adı:
# NEXT_PUBLIC_CHAT_MODEL=qwen2.5-3b-instruct-gguf

# Chat kalite/debug paneli. Normal kullanıcı deneyiminde kapalı tutun.
# NEXT_PUBLIC_R3MES_CHAT_DEBUG=1

# Ürün runtime açıklaması. Boş bırakılırsa UI ek satır göstermez.
# NEXT_PUBLIC_INFERENCE_RUNTIME_CONTEXT=Varsayılan çıkarım hattı Qwen2.5-3B; bilgi katmanı RAG, behavior LoRA isteğe bağlıdır.

# İsteğe bağlı: domainTags’te r3mes:dev-test yokken yerel test adaptörü ID’leri (virgülle). Üretimde kullanmayın.
# NEXT_PUBLIC_R3MES_DEV_TEST_ADAPTER_IDS=cuid1,cuid2



# Sui ağı: localnet | devnet | testnet | mainnet

NEXT_PUBLIC_SUI_NETWORK=testnet



# --- Testnet deploy (tx AgXkhHzvXPN4TYWNYEZnwHgQ4dKN9LTAsDS36rg4h9Yn) ---

