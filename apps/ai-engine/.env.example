# Backend seçimi:
# - llama_cpp: legacy GGUF + llama-server
# - transformers_peft: yeni Qwen + Transformers + optional PEFT adapter
R3MES_INFERENCE_BACKEND=transformers_peft

# Yalnızca legacy llama_cpp yolunda anlamlı.
R3MES_SKIP_LLAMA=1

R3MES_IPFS_GATEWAY=http://127.0.0.1:9080
R3MES_LLAMA_INTERNAL_PORT=8080

# Varsayılan çekirdek: Qwen2.5-3B Instruct GGUF
# R3MES_FROZEN_GGUF_LOCAL_PATH=C:/models/qwen2.5-3b-instruct-q5_k_m.gguf
# R3MES_FROZEN_CORE_HF_URL=https://huggingface.co/Qwen/Qwen2.5-3B-Instruct-GGUF/resolve/main/qwen2.5-3b-instruct-q5_k_m.gguf

# Yeni ana yol: Transformers/PEFT
# R3MES_HF_MODEL_LOCAL_PATH=C:/r3mes-hf-model-cache/Qwen2.5-3B-Instruct
# R3MES_HF_MODEL_NAME_OR_PATH=Qwen/Qwen2.5-3B-Instruct
# Reranker (aynı ai-engine içinde çalışır)
# R3MES_RERANKER_LOCAL_PATH=C:/r3mes-hf-model-cache/bge-reranker-base
# R3MES_RERANKER_MODEL_NAME_OR_PATH=BAAI/bge-reranker-base
# R3MES_RERANKER_DEVICE=cpu

# Embedding endpoint (/v1/embeddings) — Qdrant RAG v2 için.
# GPU varsa cuda önerilir; local path yoksa local_files_only=0 ile HF'den indirilebilir.
# R3MES_EMBEDDING_LOCAL_PATH=C:/r3mes-hf-model-cache/bge-m3
# R3MES_EMBEDDING_MODEL_NAME_OR_PATH=BAAI/bge-m3
# R3MES_EMBEDDING_DEVICE=cuda
# R3MES_EMBEDDING_LOCAL_FILES_ONLY=1
